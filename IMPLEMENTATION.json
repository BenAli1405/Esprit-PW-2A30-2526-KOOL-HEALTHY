  "algorithm": {
    "name": "K-Nearest Neighbors (KNN)",
    "dimensions": 4,
    "features": [
      "intensite_calorique [0, 1]",
      "equipement [0, 1]",
      "difficulte [0, 1]",
      "cible_musculaire [0, 1]"
    ],
    "distance": "Euclidienne",
    "formula": "sqrt((I1-I2)² + (E1-E2)² + (D1-D2)² + (C1-C2)²)",
    "k_default": 3,
    "complexity": "O(n)",
    "normalization": {
      "min": 0,
      "max": 1,
      "intensity": "0=low, 1=high",
      "equipment": "0=bodyweight, 1=heavy",
      "difficulty": "0=beginner, 1=advanced",
      "target": "0=small, 1=large"
    }
  },

  "api": {
    "provider": "WorkoutX",
    "base_url": "https://api.workoutxapp.com/v1",
    "endpoint": "/exercises",
    "auth": "X-WorkoutX-Key header",
    "response": "JSON",
    "fields_extracted": [
      "equipment",
      "difficulty",
      "target/bodyPart"
    ],
    "rate_limit": "Check WorkoutX docs",
    "free_tier": "Available"
  },

